# Path to your Google Service Account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json

# Google Drive folder ID to scope all operations
# Found in the URL: https://drive.google.com/drive/folders/<THIS_PART>
TARGET_FOLDER_IDS=your_actual_folder_id_1,your_actual_folder_id_2,your_actual_folder_id_3
